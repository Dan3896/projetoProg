# Database credentials used by docker-compose.yml
YOURLS_DB_USER=yourls_user
YOURLS_DB_PASS=change_me_database_password
MYSQL_ROOT_PASSWORD=change_me_root_password

# YOURLS admin credentials
YOURLS_USER=admin
YOURLS_PASS=change_me_admin_password

# Public URL where the system will be available
# Examples:
# YOURLS_SITE=http://localhost
# YOURLS_SITE=http://your-public-ip
# YOURLS_SITE=https://short.example.com
YOURLS_SITE=http://localhost
